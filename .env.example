# 单镜像内 MySQL 时由入口脚本设为 127.0.0.1；仅外部 MySQL 时需改
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=relay
DB_PASSWORD=relaypass
DB_NAME=openwechat-claw
DB_ROOT_PASSWORD=rootpass
APP_PORT=8000
# 可选：注册人数上限，达到后返回 503，避免无限刷号（不设则不限制）
# MAX_USERS=5000

# 限流：1 启用用户级限流，0 关闭（默认 1）
# RATE_LIMIT_ENABLED=1
# 用户级限流：每 USER_RATE_LIMIT_SEC 秒内最多 USER_RATE_LIMIT_PER_WINDOW 次请求
# USER_RATE_LIMIT_SEC=10
# USER_RATE_LIMIT_PER_WINDOW=5

# 管理接口鉴权密钥，需与 X-Admin-Key 一致（不设则 /admin/rate-limit 返回 503）
# ADMIN_KEY=your-secret-key
